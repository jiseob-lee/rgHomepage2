	<!--
	allowed-origins="http://jisblee.me:4000, http://www.jisblee.me:4000, http://jisblee.me, http://www.jisblee.me, https://www.jisblee.me, https://jisblee.me"
	-->
	<mvc:cors>
	
		<mvc:mapping path="/**"
			allowed-origins="http://jisblee.me:4000, http://www.jisblee.me:4000, http://jisblee.me, http://www.jisblee.me, https://www.jisblee.me, https://jisblee.me, http://test.jisblee.me, http://localhost:4200, https://api.tosspayments.com, http://localhost:8080"
			allowed-methods="GET, PUT, POST, OPTIONS"
			allowed-headers="X-CSRF-HEADER, X-CSRF-PARAM, X-CSRF-TOKEN, Accept, Content-Type, Cache-Control, Access-Control-Allow-Origin, Pragma, Expires, withCredentials, Cookie"
			exposed-headers=""
			allow-credentials="true"
			max-age="123" />

