<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rg2.mssqlsp.MssqlSPMapper">

	<resultMap id="userResultMap" type="java.util.HashMap"></resultMap>

	<parameterMap type="java.util.HashMap" id="UserencParam">
		<parameter property="TABLELIST" jdbcType="CURSOR" mode="OUT" resultMap="userResultMap"/>
	</parameterMap>

	<!-- 출처: https://ratinel.tistory.com/entry/MyBatis오라클-Cursor-리턴-받기 [개발과 나의꿈] -->


	<select id="getTable1" statementType="CALLABLE" parameterType="java.util.Map" resultType="java.util.HashMap">
		
		{CALL uspCurrencyCursor2()}

	</select>

	<select id="getTable2" statementType="CALLABLE" parameterType="java.util.Map" resultType="java.util.HashMap">
		
		{CALL uspCurrencyCursor1(
		#{vcursor, mode=OUT, jdbcType=CURSOR, javaType=ResultSet, resultMap=userResultMap}
		)}

	</select>
	<!-- #{result, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=userResultMap} -->
</mapper>