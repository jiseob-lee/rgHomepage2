<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rg.accesslog.AccessLogMapper">

	<select id="getArticleSubject" parameterType="String" resultType="String">
	
		SELECT
			c.subject
		
		FROM
			board_article c
		
		WHERE
			c.board_article_idx = #{board_article_idx}

	</select>


</mapper>
