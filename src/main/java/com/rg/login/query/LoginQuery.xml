	<select id="loginProcess" resultType="string">
	<![CDATA[
		/* loginProcess */
		
		SELECT
			USER_ID
		FROM
			user
		WHERE
			USER_ID = #{userId}
			AND USER_PASSWORD = #{userPassword}
			AND USER_PASSWORD IS NOT NULL
	]]>
	</select>

	<select id="getUserName" resultType="string">
		
		SELECT
			USER_NAME_KO
		FROM
			user
		WHERE
			USER_ID = #{userId, jdbcType=VARCHAR}

	</select>
	
</mapper>