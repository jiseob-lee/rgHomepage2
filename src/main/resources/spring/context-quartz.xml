	<bean name="redisFlushJob" class="org.springframework.scheduling.quartz.JobDetailFactoryBean"><!-- Quartz 2.x 버전 -->
		<property name="jobClass">
			<value>com.rg.login.controller.RedisFlush</value>
		</property>
		<property name="applicationContextJobDataKey" value="applicationContext" />
	</bean>
	
	<bean id="redisFlushTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean"><!-- Quartz 2.x 버전 -->

		<property name="jobDetail">
			<ref bean="redisFlushJob"/>
		</property>
		<property name="cronExpression">
			<!-- 매  5분마다 실행 --> 
			<!-- <value>0 0/5 * * * ?</value> -->
			<!-- 매일 새벽 3시 0분 마다 실행  -->
			<value>0 0 3 * * ?</value>
			<!-- <value>0 32 0/1 * * ?</value> -->
			
			<!-- <value>0 10 2,4 * * ?</value> -->
			
			<!-- <value>0 10 14 * * ?</value> -->

		</property>
	</bean>
	
	<bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
				<!-- <ref bean="redisFlushTrigger"/> -->
				<!--
